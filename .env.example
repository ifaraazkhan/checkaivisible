# Database (Postgres connection string). All objects live in the `cav1` schema.
# Local dev:  postgresql://postgres@localhost:5432/checkaivisible
# Production: Railway/Neon/Supabase connection string
DATABASE_URL=

# OpenAI — platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini — aistudio.google.com (Get API key)
GEMINI_API_KEY=

# Google Places API (New) — console.cloud.google.com, enable Places API (New)
GOOGLE_PLACES_API_KEY=

# Cloudflare Turnstile — dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Perplexity — perplexity.ai → Settings → API
PERPLEXITY_API_KEY=

# Google OAuth (Auth.js login) — console.cloud.google.com → Credentials → OAuth 2.0 Client (Web)
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Auth.js session secret — generate: openssl rand -base64 32
AUTH_SECRET=

# Dodo Payments (merchant-of-record) — app.dodopayments.com → Developer
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_ENVIRONMENT=test_mode   # test_mode | live_mode
DODO_PRODUCT_ONETIME=                 # product id for the one-time fix report
DODO_PRODUCT_SUBSCRIPTION=            # product id for the recurring plan

# Resend transactional email — resend.com/api-keys
# NOTE: verify the sending domain in Resend (DNS records in GoDaddy) before
# RESEND_FROM_EMAIL will deliver; until then sends only reach the account owner.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@checkaivisible.com
# Public web URL used to build report/fix-plan links inside emails.
APP_URL=https://checkaivisible.com
# Optional: get an internal email each time someone unlocks a fix plan (a new lead).
LEAD_NOTIFY_EMAIL=

# Sentry (optional) — sentry.io
SENTRY_DSN=

# Frontend → backend URL
# Local dev:    http://localhost:8787
# Production:   https://api.checkaivisible.com  (or your Railway URL)
API_URL=http://localhost:8787
NEXT_PUBLIC_API_URL=http://localhost:8787

# Site URL for canonical/og/sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (frontend). Leave blank to disable — the app no-ops without them.
# GA4 — analytics.google.com → Admin → Data Streams → Web → "Measurement ID" (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# PostHog — app.posthog.com → Project Settings → "Project API Key" (phc_...)
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog host: US cloud = https://us.i.posthog.com | EU cloud = https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Google Search Console — Settings → Ownership verification → "HTML tag" → copy the
# content="..." token only (not the whole tag). Alternatively verify via DNS in GoDaddy.
GOOGLE_SITE_VERIFICATION=

# API server config
PORT=8787
NODE_ENV=development

# Discovery pipeline governors (autonomous daily run). Both have safe code
# defaults — set here only to override.
# Hard ceiling on total live ledgers; the feeder + trend lane stop minting at this.
MAX_LIVE_LEDGERS=80
# Max brand-new ledgers the trend / user-interest lane may mint per daily pass.
MAX_TREND_MINTS_PER_DAY=2
