{
  "name": "checkaivisible",
  "version": "0.0.1",
  "private": true,
  "description": "AI visibility checker for local restaurants",
  "scripts": {
    "dev:web": "pnpm --filter @cav/web dev",
    "dev:api": "pnpm --filter @cav/api dev",
    "build:web": "pnpm --filter @cav/web build",
    "build:api": "pnpm --filter @cav/api build",
    "db:generate": "pnpm --filter @cav/db generate",
    "db:migrate": "pnpm --filter @cav/db migrate",
    "db:studio": "pnpm --filter @cav/db studio",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
